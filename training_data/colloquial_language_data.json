          {"subject": "naanu (I)", "literary": "hOguttEne", "spoken": "hOgtIni"},
          {"subject": "naavu (we)", "literary": "hOguttEve", "spoken": "hOgtIvi"},
          {"subject": "niinu (you inf)", "literary": "hOguttIye", "spoken": "hOgtIya"},
          {"subject": "nIvu (you formal)", "literary": "hOguttIri", "spoken": "hOgtIri"},
          {"subject": "avanu (he)", "literary": "hOguttAne", "spoken": "hOgtAne"},
          {"subject": "avaLu (she)", "literary": "hOguttALe", "spoken": "hOgtALe"},
          {"subject": "avaru (they/formal he)", "literary": "hOguttAre", "spoken": "hOgtAre"},
          {"subject": "adu (it)", "literary": "hOguttade", "spoken": "hOgatte"}
        ]
      },
